        "}"
    ],
    "checkver": {
        "url": "https://sourceforge.net/projects/controlremote/rss?path=/",
        "regex": "/RemoteMaster/v([\\d.]+)/RMIR.v([\\d.]+)-bin.zip"
    },
    "autoupdate": {
